// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PATIENT
  DOCTOR
  ADMIN
  MEDICAL_CENTER_ADMIN
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum LabTestStatus {
  ORDERED
  SAMPLE_COLLECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum NotificationType {
  APPOINTMENT_REMINDER
  LAB_RESULT_READY
  APPOINTMENT_CONFIRMED
  APPOINTMENT_CANCELLED
  MEDICATION_REMINDER
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  phone         String?
  dateOfBirth   DateTime?
  gender        String?
  address       String?
  emergencyContact String?
  role          UserRole  @default(PATIENT)
  language      String    @default("en")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  
  // Patient relationships
  appointments  Appointment[] @relation("PatientAppointments")
  labTests      LabTest[]
  medicalHistory MedicalHistory[]
  notifications Notification[]
  
  // Doctor relationships
  doctorAppointments Appointment[] @relation("DoctorAppointments")
  doctorProfile DoctorProfile?
  
  // Medical Center Admin relationships
  medicalCenter MedicalCenter?
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model DoctorProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  specialization  String
  licenseNumber   String   @unique
  yearsOfExperience Int
  education       String?
  certifications  String[]
  languages       String[]
  consultationFee Decimal?
  availability    Json     // Store availability schedule as JSON
  bio             String?
  rating          Float?   @default(0)
  reviewCount     Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  medicalCenter   MedicalCenter @relation(fields: [medicalCenterId], references: [id])
  medicalCenterId String
}

model MedicalCenter {
  id          String   @id @default(cuid())
  name        String
  address     String
  phone       String
  email       String
  website     String?
  latitude    Float
  longitude   Float
  description String?
  facilities  String[]
  operatingHours Json   // Store operating hours as JSON
  rating      Float?   @default(0)
  reviewCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  adminId     String   @unique
  admin       User     @relation(fields: [adminId], references: [id])
  doctors     DoctorProfile[]
  appointments Appointment[]
  labTests    LabTest[]
}

model Appointment {
  id          String            @id @default(cuid())
  patientId   String
  doctorId    String
  centerId    String
  date        DateTime
  startTime   DateTime
  endTime     DateTime
  status      AppointmentStatus @default(SCHEDULED)
  reason      String
  notes       String?
  symptoms    String?
  diagnosis   String?
  prescription String?
  followUpDate DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  patient     User          @relation("PatientAppointments", fields: [patientId], references: [id])
  doctor      User          @relation("DoctorAppointments", fields: [doctorId], references: [id])
  center      MedicalCenter @relation(fields: [centerId], references: [id])
  
  @@index([patientId])
  @@index([doctorId])
  @@index([date])
}

model LabTest {
  id          String        @id @default(cuid())
  patientId   String
  doctorId    String?
  centerId    String
  testName    String
  testType    String
  description String?
  instructions String?
  scheduledDate DateTime?
  completedDate DateTime?
  status      LabTestStatus @default(ORDERED)
  results     Json?         // Store test results as JSON
  resultsPdf  String?       // URL to PDF results
  notes       String?
  cost        Decimal?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  patient     User          @relation(fields: [patientId], references: [id])
  doctor      User?         @relation(fields: [doctorId], references: [id])
  center      MedicalCenter @relation(fields: [centerId], references: [id])
  
  @@index([patientId])
  @@index([status])
}

model MedicalHistory {
  id          String   @id @default(cuid())
  patientId   String
  date        DateTime
  type        String   // e.g., "appointment", "lab_test", "medication", "allergy", "surgery"
  title       String
  description String
  doctorName  String?
  centerName  String?
  attachments String[] // URLs to attached files
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patient     User     @relation(fields: [patientId], references: [id])
  
  @@index([patientId])
  @@index([date])
  @@index([type])
}

model Notification {
  id          String           @id @default(cuid())
  userId      String
  type        NotificationType
  title       String
  message     String
  isRead      Boolean          @default(false)
  scheduledFor DateTime?
  sentAt      DateTime?
  metadata    Json?            // Additional data specific to notification type
  createdAt   DateTime         @default(now())

  user        User             @relation(fields: [userId], references: [id])
  
  @@index([userId])
  @@index([scheduledFor])
  @@index([isRead])
}